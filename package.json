{
  "name": "lobsterpot",
  "version": "0.1.0",
  "description": "Remote coding agent orchestrator — manage multiple AI coding sessions from chat",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "lobsterpot": "dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "dashboard",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "claude-code",
    "codex",
    "aider",
    "tmux",
    "remote",
    "orchestrator",
    "openclaw"
  ],
  "author": "Jonathan Hammant",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jhammant/lobsterpot.git"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "ssh2": "^1.15.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/ssh2": "^1.15.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
